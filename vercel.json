{
    "version": 2,
    "outputDirectory": ".",
    "framework": null,
    "functions": {
        "api/index.js": {
            "memory": 256
        }
    },
    "routes": [
        { "src": "/login", "dest": "/login.html" },
        { "src": "/api/(.*)", "dest": "/api/index.js" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}
