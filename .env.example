# ============================================================
# Blog Cá Nhân - Environment Variables
# ============================================================
# Copy file này thành .env (local) hoặc cấu hình trên Vercel dashboard
# (Project Settings → Environment Variables)
# ============================================================

# ---- Auth ----
# Mật khẩu đăng nhập trang admin (login.html)
SITE_PASSWORD=123456

# Secret ký JWT (BẮT BUỘC ở production, ≥ 32 ký tự random)
# Tạo random: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---- GitHub (dùng để xuất bản/lưu content & ảnh) ----
# Personal Access Token (scope: repo)
GITHUB_TOKEN=

# Tên repo dạng username/repo
GITHUB_REPO=

# ---- Site URL (cho CORS, bỏ trống nếu chưa deploy) ----
NEXT_PUBLIC_SITE_URL=
